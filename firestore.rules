rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      let keys = data.keys();
      return keys.hasAll(['createdAt', 'updatedAt', 'displayName', 'settings']) &&
             keys.size() == 4 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.settings is map &&
             isValidSettings(data.settings);
    }

    function isValidSettings(settings) {
      let keys = settings.keys();
      return keys.hasAll(['personaName', 'selectedVoice', 'customPrompt', 'contextSize']) &&
             keys.size() == 4 &&
             settings.personaName is string && settings.personaName.size() <= 50 &&
             settings.selectedVoice is string && settings.selectedVoice.size() <= 50 &&
             settings.customPrompt is string && settings.customPrompt.size() <= 2000 &&
             settings.contextSize is number;
    }

    function isValidMessage(data) {
      let keys = data.keys();
      return keys.hasAll(['role', 'text', 'timestamp']) &&
             keys.size() == 3 &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 5000 &&
             data.timestamp is timestamp;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time && (
                        // Action: Update Profile
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt']) ||
                        // Action: Update Settings
                        incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'updatedAt'])
                      );

      match /messages/{messageId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                        isValidMessage(incoming()) &&
                        incoming().timestamp == request.time;
        
        // Messages are immutable in this app
        allow update, delete: if false;
      }
    }
  }
}
