# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SANDBOX_URL: Backend URL for sandbox + WhatsApp API routes.
# Use a same-origin/proxied URL in production when possible.
VITE_SANDBOX_URL="http://localhost:4200"

# SANDBOX_ROOT: Writable server-side output directory for generated artifacts.
SANDBOX_ROOT="./.sandbox"

# SANDBOX_PORT: Local Express backend port for sandbox + WhatsApp APIs.
SANDBOX_PORT="4200"

# WA_AUTH_ROOT: Writable server-side directory for per-user Baileys auth sessions.
# Each Firebase user gets an isolated subfolder under this path.
WA_AUTH_ROOT="./.baileys_auth"

# WA_LOG_LEVEL: Optional Baileys/Pino log level: silent, error, warn, info, debug.
WA_LOG_LEVEL="silent"

# WhatsApp Cloud API credentials are entered per user in /adminportal.
# They are stored server-side under WA_AUTH_ROOT/<firebase-user-id>/admin-config.json.

# Google OAuth Credentials
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"
VITE_GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# Firebase Credentials
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_DATABASE_URL="MY_FIREBASE_DATABASE_URL"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"


